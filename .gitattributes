# Helix-TTD Git Attributes
# Line endings: Force LF for all text files

# Default: treat all files as text with LF
* text=auto eol=lf

# Explicit LF for specific file types
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.txt text eol=lf
*.gitignore text eol=lf
