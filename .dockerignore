# [FACT] Docker build context exclusions for faster builds/smaller images

# Git
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info
dist
build

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation (not needed for runtime)
docs/
*.md
!helix_code/README.md
!helix_code/CLAUDE-QUICKSTART.md

# Images and media
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg

# Terraform (if added later)
*.tfstate
*.tfstate.*
.terraform/

# Local test receipts
helix_code/docs/receipts/deepseek/*.json
helix_code/logs/
helix_code/telemetry/
helix_code/audits/
helix_code/__pycache__/

# pytest cache
.pytest_cache/
.coverage
htmlcov/

# Temporary files
temp/
*.tmp
